{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chadangcms",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "pnpm run build"
  },
  "main": "./src/worker.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/__env*"],
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": ["nodejs_compat"]
}
